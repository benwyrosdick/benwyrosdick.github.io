---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Scripts from '../components/Scripts.astro';
import { siteConfig } from '../site.config';
import '../styles/main.scss';

interface Props {
  title: string;
  date: Date;
  image?: string;
  image2?: string;
  author?: string;
  description?: string;
}

const { title, date, image, image2, author, description } = Astro.props;
const displayAuthor = author ?? siteConfig.author;
const longDate = date.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDateMinute = `${date.toISOString().slice(0, 10)} ${date
  .toISOString()
  .slice(11, 16)}`;
---

<!DOCTYPE html>
<html lang="en">
  <Head title={title} description={description} image={image} publishedDate={date} />
  <body itemscope itemtype="http://schema.org/Article">
    <Header />
    <main class="content" role="main">
      <article class="post">
        {image ? (
          <div class="article-image">
            <div class="post-image-image" style={`background-image: url(${image})`}>
              Article Image
            </div>
            {image2 && (
              <div class="post-image-image2" style={`background-image: url(${image2})`}>
                Article Image
              </div>
            )}
            <div class="post-meta">
              <h1 class="post-title">{title}</h1>
              <div class="cf post-meta-text">
                <div class="author-image" style={`background-image: url(${siteConfig.authorImage})`}>
                  Blog Logo
                </div>
                <h4 class="author-name" itemprop="author" itemscope itemtype="http://schema.org/Person">
                  {displayAuthor}
                </h4>
                on <time datetime={isoDateMinute}>{longDate}</time>
              </div>
              <div style="text-align:center">
                <a href="#topofpage" class="topofpage"><i class="fa fa-angle-down"></i></a>
              </div>
            </div>
          </div>
        ) : (
          <div class="noarticleimage">
            <div class="post-meta">
              <h1 class="post-title">{title}</h1>
              <div class="cf post-meta-text">
                <div class="author-image" style={`background-image: url(${siteConfig.authorImage})`}>
                  Blog Logo
                </div>
                <h4 class="author-name" itemprop="author" itemscope itemtype="http://schema.org/Person">
                  {displayAuthor}
                </h4>
                on <time datetime={date.toISOString()}>{longDate}</time>
              </div>
            </div>
            <br /><br /><br />
          </div>
        )}

        <section class="post-content">
          <a name="topofpage"></a>
          <slot />
        </section>

        <footer class="post-footer">
          <section class="share">
            {siteConfig.social
              .filter((s) => s.shareUrl)
              .map((s) => (
                <a
                  class={`icon-${s.icon}`}
                  href={`${s.shareUrl}${s.shareTitle}${encodeURIComponent(title)}${s.shareLink}${siteConfig.url}${Astro.url.pathname}`}
                  onclick={`window.open(this.href, '${s.icon}-share', 'width=550,height=255');return false;`}
                >
                  <i class={`fa fa-${s.icon}`}></i><span class="hidden">{s.icon}</span>
                </a>
              ))}
          </section>
        </footer>

        <div class="bottom-teaser cf">
          <div class="isLeft">
            <h5 class="index-headline featured"><span>Written by</span></h5>
            <section class="author">
              <div class="author-image" style={`background-image: url(${siteConfig.authorImage})`}>
                Blog Logo
              </div>
              <h4>{siteConfig.author}</h4>
              <hr />
              <p class="published">
                Published <time datetime={isoDateMinute}>{longDate}</time>
              </p>
            </section>
          </div>
          <div class="isRight">
            <h5 class="index-headline featured"><span>Supported by</span></h5>
            <footer class="site-footer">
              <section class="poweredby">
                Proudly published with <a href="https://jekyllrb.com/">Jekyll</a>
              </section>
              <a class="subscribe" href="/feed.xml">
                <span class="tooltip"><i class="fa fa-rss"></i> You should subscribe to my feed.</span>
              </a>
              <div class="inner">
                <section class="copyright">
                  All content copyright <a href={siteConfig.url}>{siteConfig.author}</a>
                  &copy; {new Date().getFullYear()}<br />All rights reserved.
                </section>
              </div>
            </footer>
          </div>
        </div>
      </article>
    </main>

    <div class="bottom-closer">
      <div class="background-closer-image" style={`background-image: url(${siteConfig.cover})`}>
        Image
      </div>
      <div class="inner">
        <h1 class="blog-title">{siteConfig.title}</h1>
        <h2 class="blog-description">{siteConfig.description}</h2>
        <a href="/" class="btn">Back to Overview</a>
      </div>
    </div>

    <Scripts />
  </body>
</html>
