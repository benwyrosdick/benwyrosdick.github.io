---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/main.scss';

interface Props {
  appName: string;
  pageTitle: string;
  description?: string;
}

const { appName, pageTitle, description } = Astro.props;
const fullTitle = `${appName} – ${pageTitle}`;
---

<!DOCTYPE html>
<html lang="en">
  <Head title={fullTitle} description={description} />
  <body>
    <Header />
    <main class="content app-page" role="main">
      <header class="app-page-header">
        <p class="app-page-eyebrow">{appName}</p>
        <h1 class="app-page-title">{pageTitle}</h1>
      </header>
      <section class="app-page-body">
        <slot />
      </section>
    </main>
    <Footer />
  </body>
</html>

<style lang="scss">
  .app-page {
    max-width: 720px;
    padding: 80px 24px 60px;
    font-family: "Open Sans", "Helvetica Neue", Arial, sans-serif;
    color: #333;
  }

  .app-page-header {
    margin-bottom: 32px;
  }

  .app-page-eyebrow {
    margin: 0 0 8px;
    font-size: 14px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #b3b3b1;
  }

  .app-page-title {
    margin: 0;
    font-size: 36px;
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #222;
  }

  .app-page-body :global(h2) {
    margin-top: 36px;
    font-size: 22px;
    font-weight: 700;
    color: #222;
  }

  .app-page-body :global(h3) {
    margin-top: 28px;
    font-size: 18px;
    font-weight: 700;
    color: #222;
  }

  .app-page-body :global(p),
  .app-page-body :global(li) {
    font-size: 16px;
    line-height: 1.6;
    color: #333;
  }

  .app-page-body :global(ul),
  .app-page-body :global(ol) {
    padding-left: 22px;
  }

  .app-page-body :global(a) {
    color: #2c6e49;
    text-decoration: underline;
  }

  .app-page-body :global(.muted) {
    color: #999;
    font-size: 14px;
  }
</style>
