---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogHeader from '../components/BlogHeader.astro';
import PostList from '../components/PostList.astro';
import { siteConfig } from '../site.config';
import { getSortedPosts } from '../lib/posts';

const posts = await getSortedPosts();
const perPage = siteConfig.paginate;
const pageData = posts.slice(0, perPage);
const totalPages = Math.max(1, Math.ceil(posts.length / perPage));
---

<BaseLayout>
  <div class="teaserimage">
    <div class="teaserimage-image" style={`background-image: url(${siteConfig.cover})`}>
      Teaser Image
    </div>
  </div>

  <BlogHeader />

  <main class="content" role="main">
    <PostList posts={pageData} />

    {totalPages > 1 && (
      <nav class="pagination" role="navigation">
        <a class="newer-posts" href="/page/2/">&larr; Older posts</a>
        <span class="page-number">Page 1 of {totalPages}</span>
      </nav>
    )}
  </main>
</BaseLayout>
