---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import imposterIcon from '../../assets/imposter/app-icon.png';
import batteryscopeIcon from '../../assets/batteryscope/app-icon.png';
import gamenightIcon from '../../assets/gamenight/app-icon.png';
import dockitIcon from '../../assets/dockit/app-icon.png';
import openusageIcon from '../../assets/openusage-waybar/app-icon.png';

interface AppEntry {
  slug: string;
  name: string;
  tagline: string;
  description: string;
  /** App-store style icon. Omit for CLI/TUI tools to render a terminal glyph. */
  icon?: ImageMetadata;
  accent: string;
  status: string;
  /** Where the main card links. Defaults to the internal product page. */
  href?: string;
  external?: boolean;
  cta?: string;
  /** Footer links. Defaults to the internal Privacy / Support pages. */
  links?: { label: string; href: string }[];
}

interface AppSection {
  id: string;
  title: string;
  blurb: string;
  apps: AppEntry[];
}

const sections: AppSection[] = [
  {
    id: 'ios',
    title: 'iOS',
    blurb: 'Built for iPhone. All local, no accounts, no tracking.',
    apps: [
      {
        slug: 'gamenight',
        name: 'Gamenight Scoreboard',
        tagline: 'Simple game night score keeper',
        description:
          'Track scores round by round. Customize rules with timed rounds, phase tracking, and auto-end target scores. Fully offline and private.',
        icon: gamenightIcon,
        accent: '#ffc24a',
        status: 'TestFlight beta',
      },
      {
        slug: 'imposter',
        name: 'Imposter',
        tagline: 'Pass-and-play party game',
        description:
          "Pass your phone around the table. Everyone sees a secret word — except the imposters. Talk it out, guess who's faking, play again.",
        icon: imposterIcon,
        accent: '#b07cf6',
        status: 'On the App Store',
      },
      {
        slug: 'batteryscope',
        name: 'BatteryScope',
        tagline: 'Bluetooth BMS monitor',
        description:
          'Live stats from your lithium batteries — voltage, current, state of charge, cell balance, time-to-empty. Works with JBD / Xiaoxiang-protocol BMS modules.',
        icon: batteryscopeIcon,
        accent: '#2dd47a',
        status: 'On the App Store',
      },
    ],
  },
  {
    id: 'desktop',
    title: 'Desktop',
    blurb: 'Native apps for the Mac and Linux desktop.',
    apps: [
      {
        slug: 'dockit',
        name: 'Dockit',
        tagline: 'A native Docker GUI',
        description:
          'Manage Docker without the command line. Browse containers, images, volumes, and networks, stream live logs, watch CPU and memory, and run Compose projects — all from a fast native desktop app.',
        icon: dockitIcon,
        accent: '#34c9a3',
        status: 'Open source · macOS & Linux',
        href: 'https://github.com/benwyrosdick/dockit',
        external: true,
        cta: 'View on GitHub',
        links: [
          { label: 'Download', href: 'https://github.com/benwyrosdick/dockit/releases' },
          { label: 'Source', href: 'https://github.com/benwyrosdick/dockit' },
        ],
      },
      {
        slug: 'openusage-waybar',
        name: 'OpenUsage Waybar',
        tagline: 'AI usage in your status bar',
        description:
          'A Waybar module that tracks AI coding subscription usage — Claude, Copilot, Cursor — right from your desktop. Live progress bars and tooltips so you can watch quotas and credits at a glance.',
        icon: openusageIcon,
        accent: '#aee23a',
        status: 'Open source · Linux/Wayland',
        href: 'https://github.com/benwyrosdick/openusage-waybar',
        external: true,
        cta: 'View on GitHub',
        links: [
          { label: 'Source', href: 'https://github.com/benwyrosdick/openusage-waybar' },
        ],
      },
    ],
  },
  {
    id: 'cli',
    title: 'CLI / TUI',
    blurb: 'Terminal tools for the keyboard-driven. Free and open source.',
    apps: [
      {
        slug: 'lazylinear',
        name: 'LazyLinear',
        tagline: 'Linear issues in the terminal',
        description:
          'A lazygit-style TUI for Linear. Browse, create, edit, and manage issues without leaving the terminal — with multi-team workflows, status filtering, and one-key copy of URLs and branch names.',
        accent: '#5e6ad2',
        status: 'Open source · Go',
        href: 'https://github.com/benwyrosdick/lazylinear',
        external: true,
        cta: 'View on GitHub',
        links: [
          { label: 'Source', href: 'https://github.com/benwyrosdick/lazylinear' },
        ],
      },
      {
        slug: 'restui',
        name: 'restui',
        tagline: 'Postman in your terminal',
        description:
          'A terminal API client built with Rust and Ratatui. Fire HTTP requests, organize collections, manage environment variables and auth, and read responses with syntax highlighting and jq filtering.',
        accent: '#e06c75',
        status: 'Open source · Rust',
        href: 'https://github.com/benwyrosdick/restui',
        external: true,
        cta: 'View on GitHub',
        links: [
          { label: 'Source', href: 'https://github.com/benwyrosdick/restui' },
        ],
      },
      {
        slug: 'wxman',
        name: 'wxman',
        tagline: 'Weather in your terminal',
        description:
          'A weather TUI built with Rust and Ratatui. Current conditions, hourly and 5-day forecasts with color-coded temperatures and icons, auto-location via IP, and a refresh every 15 minutes.',
        accent: '#56b6c2',
        status: 'Open source · Rust',
        href: 'https://github.com/benwyrosdick/wxman',
        external: true,
        cta: 'View on GitHub',
        links: [
          { label: 'Source', href: 'https://github.com/benwyrosdick/wxman' },
        ],
      },
      {
        slug: 'git-recent',
        name: 'git-recent',
        tagline: 'Jump to recent branches',
        description:
          'A tiny CLI that lists your git branches by most recent activity in an interactive menu. Filter, pick, and check out — no more squinting at branch names you half remember.',
        accent: '#f0a050',
        status: 'Open source · Go',
        href: 'https://github.com/benwyrosdick/git-recent',
        external: true,
        cta: 'View on GitHub',
        links: [
          { label: 'Source', href: 'https://github.com/benwyrosdick/git-recent' },
        ],
      },
    ],
  },
];
---

<BaseLayout
  title="Apps – Ben Wyrosdick"
  description="iOS, desktop, and command-line apps built by Ben Wyrosdick."
>
  <section class="apps-hero">
    <div class="apps-hero-bg" aria-hidden="true"></div>
    <div class="apps-hero-inner">
      <p class="apps-eyebrow">Apps</p>
      <h1>Things I'm making</h1>
      <p class="apps-lead">
        A small collection of iOS, desktop, and command-line apps I build in evenings and
        weekends. Mostly local, mostly open source, no tracking.
      </p>
    </div>
  </section>

  {sections.map((section) => (
    <section class="apps-grid-section">
      <div class="apps-section-head">
        <h2 class="apps-section-title">{section.title}</h2>
        <p class="apps-section-blurb">{section.blurb}</p>
      </div>
      <ul class="apps-grid">
        {section.apps.map((app) => {
          const cardHref = app.href ?? `/apps/${app.slug}/`;
          const cta = app.cta ?? 'View product page';
          const links = app.links ?? [
            { label: 'Privacy', href: `/apps/${app.slug}/privacy/` },
            { label: 'Support', href: `/apps/${app.slug}/support/` },
          ];
          const external = app.external ?? false;
          return (
            <li class="app-card" style={`--app-accent: ${app.accent}`}>
              <a
                href={cardHref}
                class="app-card-link"
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener noreferrer' : undefined}
              >
                <div class="app-card-head">
                  {app.icon ? (
                    <Image
                      src={app.icon}
                      alt={`${app.name} app icon`}
                      widths={[96, 192]}
                      sizes="96px"
                      class="app-card-icon"
                    />
                  ) : (
                    <div class="app-card-icon app-card-icon--cli" aria-hidden="true">
                      <span>&gt;_</span>
                    </div>
                  )}
                  <div class="app-card-id">
                    <h3>{app.name}</h3>
                    <p class="app-card-tagline">{app.tagline}</p>
                  </div>
                </div>
                <p class="app-card-desc">{app.description}</p>
                <div class="app-card-footer">
                  <span class="app-card-status">{app.status}</span>
                  <span class="app-card-cta">
                    {cta}
                    <span class="app-card-arrow" aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
              <div class="app-card-links">
                {links.map((link, i) => (
                  <>
                    {i > 0 && <span>·</span>}
                    <a
                      href={link.href}
                      target={external ? '_blank' : undefined}
                      rel={external ? 'noopener noreferrer' : undefined}
                    >{link.label}</a>
                  </>
                ))}
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  ))}
</BaseLayout>

<style lang="scss">
  $bg-1: #0a1130;
  $bg-2: #161a3e;
  $text: #ecedf6;
  $muted: #9aa1c4;
  $card-border: rgba(255, 255, 255, 0.08);

  :global(body) {
    background: $bg-1;
  }

  .apps-hero {
    position: relative;
    overflow: hidden;
    color: $text;
    padding: 96px 24px 56px;

    @media (max-width: 720px) {
      padding: 80px 20px 40px;
    }
  }

  .apps-hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 0%, rgba(176, 124, 246, 0.2), transparent 55%),
      radial-gradient(circle at 90% 100%, rgba(45, 212, 122, 0.18), transparent 60%),
      linear-gradient(165deg, $bg-1, $bg-2 75%);
    z-index: 0;
  }

  .apps-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .apps-eyebrow {
    margin: 0 0 12px;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: $muted;
  }

  .apps-hero-inner h1 {
    margin: 0 0 18px;
    font-size: 52px;
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: #fff;

    @media (max-width: 720px) { font-size: 40px; }
  }

  .apps-lead {
    margin: 0 auto;
    max-width: 30em;
    font-size: 18px;
    line-height: 1.55;
    color: $muted;
  }

  .apps-grid-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px 24px 8px;

    &:last-of-type {
      padding-bottom: 96px;
    }

    @media (max-width: 720px) {
      padding: 16px 20px 8px;

      &:last-of-type {
        padding-bottom: 72px;
      }
    }
  }

  .apps-section-head {
    margin: 24px 0 20px;
  }

  .apps-section-title {
    margin: 0 0 6px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
  }

  .apps-section-blurb {
    margin: 0;
    color: $muted;
    font-size: 15px;
    line-height: 1.5;
  }

  .apps-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;

    @media (max-width: 720px) {
      grid-template-columns: 1fr;
    }
  }

  .app-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid $card-border;
    border-radius: 22px;
    padding: 28px;
    transition: border-color 0.15s ease, transform 0.15s ease;
    position: relative;

    &:hover {
      border-color: var(--app-accent);
      transform: translateY(-2px);
    }
  }

  .app-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .app-card-head {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 18px;
  }

  .app-card-icon {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.4);
    flex-shrink: 0;
  }

  .app-card-icon--cli {
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(150deg, color-mix(in srgb, var(--app-accent) 26%, #0c1230), #0c1230);
    border: 1px solid color-mix(in srgb, var(--app-accent) 45%, transparent);

    span {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 26px;
      font-weight: 700;
      color: var(--app-accent);
      letter-spacing: -0.02em;
    }
  }

  .app-card-id {
    h3 {
      margin: 0 0 4px;
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.01em;
    }
  }

  .app-card-tagline {
    margin: 0;
    color: var(--app-accent);
    font-size: 14px;
    font-weight: 600;
  }

  .app-card-desc {
    margin: 0 0 24px;
    color: $muted;
    font-size: 15px;
    line-height: 1.55;
  }

  .app-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .app-card-status {
    color: $muted;
    font-size: 13px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .app-card-cta {
    color: var(--app-accent);
    font-weight: 600;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .app-card-arrow {
    transition: transform 0.15s ease;
  }

  .app-card:hover .app-card-arrow {
    transform: translateX(3px);
  }

  .app-card-links {
    margin-top: 18px;
    padding-top: 18px;
    border-top: 1px solid $card-border;
    display: flex;
    align-items: center;
    gap: 10px;
    color: $muted;
    font-size: 13px;

    a {
      color: $muted;
      text-decoration: none;

      &:hover {
        color: $text;
      }
    }
  }

  :global(.site-footer) {
    color: rgba(255, 255, 255, 0.5);
    a { color: rgba(255, 255, 255, 0.75); }
    a:hover { color: #fff; }
  }
</style>
