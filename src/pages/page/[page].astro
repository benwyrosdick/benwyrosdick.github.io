---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogHeader from '../../components/BlogHeader.astro';
import PostList from '../../components/PostList.astro';
import { siteConfig } from '../../site.config';
import { getSortedPosts } from '../../lib/posts';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getSortedPosts();
  // Page 1 is served by /, so skip it here.
  return paginate(posts, { pageSize: siteConfig.paginate }).filter(
    (entry) => entry.params.page !== '1' && entry.params.page !== 1,
  );
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const prevHref = page.currentPage > 2 ? `/page/${page.currentPage - 1}/` : '/';
---

<BaseLayout>
  <BlogHeader />

  <main class="content" role="main">
    <PostList posts={page.data} />

    <nav class="pagination" role="navigation">
      {page.url.next && (
        <a class="newer-posts" href={`/page/${page.currentPage + 1}/`}>&larr; Older posts</a>
      )}
      <span class="page-number">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.prev && <a class="older-posts" href={prevHref}>Newer posts &rarr;</a>}
    </nav>
  </main>
</BaseLayout>
