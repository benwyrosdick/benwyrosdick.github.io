---
// Experimental "about me" page rendered as the unix `top` command.
// Uptime is measured from Ben's birthday; processes are his day job and
// public GitHub side projects. GitHub is fetched at build time with a
// baked-in fallback so the build never depends on the network.

const BIRTH = '1980-08-02T00:00:00';

// Fallback snapshot so dev/build works offline or when rate-limited.
const FALLBACK: Repo[] = [
  { name: 'streamdeck-tailscale', lang: 'Python', size: 36, created: '2026-06-07', pushed: '2026-06-07' },
  { name: 'openusage-waybar', lang: 'JavaScript', size: 590, created: '2026-05-01', pushed: '2026-06-05' },
  { name: 'dev-tools', lang: 'TypeScript', size: 274, created: '2025-08-13', pushed: '2026-05-18' },
  { name: 'tuical', lang: 'Rust', size: 70, created: '2026-05-15', pushed: '2026-05-16' },
  { name: 'bms-manager', lang: 'Swift', size: 2906, created: '2026-05-10', pushed: '2026-05-13' },
  { name: 'dockit', lang: 'TypeScript', size: 1901, created: '2026-03-19', pushed: '2026-04-28' },
  { name: 'git-recent', lang: 'Go', size: 9, created: '2025-10-29', pushed: '2026-04-13' },
  { name: 'homebrew-tap', lang: 'Ruby', size: 14, created: '2026-01-19', pushed: '2026-02-15' },
  { name: 'lazychess', lang: 'Rust', size: 181, created: '2025-12-30', pushed: '2026-02-15' },
  { name: 'restui', lang: 'Rust', size: 983, created: '2026-01-18', pushed: '2026-01-27' },
  { name: 'wxman', lang: 'Rust', size: 857, created: '2026-01-02', pushed: '2026-01-20' },
  { name: 'js-record', lang: 'TypeScript', size: 318, created: '2025-11-11', pushed: '2025-11-13' },
];

interface Repo {
  name: string;
  lang: string | null;
  size: number;
  created: string;
  pushed: string;
}

interface Proc {
  pid: number;
  user: string;
  pr: string;
  ni: number;
  virt: number;
  res: number;
  shr: number;
  s: string;
  cpu: number;
  mem: number;
  time: string;
  cmd: string;
  kind: 'kernel' | 'job' | 'project';
}

async function loadRepos(): Promise<Repo[]> {
  try {
    const res = await fetch(
      'https://api.github.com/users/benwyrosdick/repos?per_page=100&sort=pushed',
      { headers: { 'User-Agent': 'benwyrosdick.com' } }
    );
    if (!res.ok) throw new Error(`status ${res.status}`);
    const data = (await res.json()) as any[];
    const repos = data
      .filter((r) => !r.fork && !r.archived)
      .slice(0, 12)
      .map((r) => ({
        name: r.name,
        lang: r.language,
        size: r.size,
        created: r.created_at.slice(0, 10),
        pushed: r.pushed_at.slice(0, 10),
      }));
    return repos.length ? repos : FALLBACK;
  } catch {
    return FALLBACK;
  }
}

const now = Date.now();
const DAY = 86_400_000;
const daysBetween = (a: number, b: number) => Math.max(0, Math.floor((b - a) / DAY));

const repos = await loadRepos();

// Map a repo to a top-style process.
function repoToProc(r: Repo, i: number): Proc {
  const created = new Date(r.created + 'T00:00:00').getTime();
  const pushed = new Date(r.pushed + 'T00:00:00').getTime();
  const daysActive = Math.max(1, daysBetween(created, pushed));
  const daysIdle = daysBetween(pushed, now);

  // Recently pushed -> "hot" (higher %CPU); long idle decays toward 0.
  const cpu = Math.max(0.1, +(62 * Math.exp(-daysIdle / 45)).toFixed(1));
  const s = daysIdle < 21 ? 'R' : daysIdle > 300 ? 'Z' : 'S';

  // Memory derived from repo size (KiB) presented in MiB.
  const resMiB = Math.max(2, Math.round(r.size / 8));
  const virt = resMiB * 5 + 142;
  const shr = Math.round(resMiB / 4) + 8;
  const mem = +Math.min(48, (resMiB / 64000) * 100).toFixed(1);

  // TIME+ ~= accumulated effort: 1 active day == 1 minute of CPU time.
  const totalSecs = daysActive * 60;
  const mm = Math.floor(totalSecs / 60);
  const ss = totalSecs % 60;
  const time = `${mm}:${String(ss).padStart(2, '0')}.${String((r.name.length * 7) % 100).padStart(2, '0')}`;

  const cmd = r.lang ? `${r.name} --lang=${r.lang.toLowerCase()}` : r.name;

  return {
    pid: 1024 + i * 173 + (r.size % 97),
    user: 'ben',
    pr: '20',
    ni: 5,
    virt,
    res: resMiB,
    shr,
    s,
    cpu,
    mem,
    time,
    cmd,
    kind: 'project',
  };
}

const yearsAlive = daysBetween(new Date(BIRTH).getTime(), now) / 365.25;
const lifeTime = `${Math.floor(yearsAlive * 365.25 * 1440 / 60)}:00.00`;

const special: Proc[] = [
  {
    pid: 2, user: 'ben', pr: 'rt', ni: 0, virt: 999999, res: 60200, shr: 4096,
    s: 'R', cpu: 57.3, mem: 22.1, time: lifeTime, cmd: '[family] --wife --kids=3', kind: 'kernel',
  },
  {
    pid: 1980, user: 'ben', pr: '20', ni: 0, virt: 482140, res: 248900, shr: 18240,
    s: 'R', cpu: 88.6, mem: 18.4, time: '9214:32.07',
    cmd: 'vesyl --warehouse --orders --fulfillment', kind: 'job',
  },
];

const procs: Proc[] = [...special, ...repos.map(repoToProc)];

const payload = JSON.stringify({ birth: BIRTH, procs });
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>top - ben@benwyrosdick</title>
    <meta name="description" content="Ben Wyrosdick — about, rendered as the unix top command." />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <div class="term">
      <div class="titlebar">
        <span class="dots"><i class="r"></i><i class="y"></i><i class="g"></i></span>
        <span class="title">ben@benwyrosdick: ~ — top</span>
      </div>
      <pre id="screen" class="screen" aria-label="about, as the top command">loading…</pre>
    </div>

    <noscript>
      <p style="font-family: monospace; color:#c0c0c0; padding: 1rem;">
        This page renders with JavaScript. Read the plain version on the
        <a href="/about" style="color:#7aa2f7;">about page</a>.
      </p>
    </noscript>

    <script type="application/json" id="top-data" set:html={payload}></script>

    <script>
      type Proc = {
        pid: number; user: string; pr: string; ni: number;
        virt: number; res: number; shr: number; s: string;
        cpu: number; mem: number; time: string; cmd: string;
        kind: 'kernel' | 'job' | 'project';
      };

      const data = JSON.parse(
        document.getElementById('top-data')!.textContent!
      ) as { birth: string; procs: Proc[] };

      const BIRTH = new Date(data.birth);
      let base = data.procs.map((p) => ({ ...p, baseCpu: p.cpu }));
      let load = [1.21, 1.08, 0.94];

      const esc = (s: string) =>
        s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const pad = (s: string | number, n: number) => String(s).padStart(n);
      const padE = (s: string | number, n: number) => String(s).padEnd(n);
      const rand = (a: number, b: number) => a + Math.random() * (b - a);
      const two = (n: number) => String(n).padStart(2, '0');

      function uptime(now: Date) {
        let years = now.getFullYear() - BIRTH.getFullYear();
        let anniv = new Date(now.getFullYear(), BIRTH.getMonth(), BIRTH.getDate());
        if (now < anniv) {
          years -= 1;
          anniv = new Date(now.getFullYear() - 1, BIRTH.getMonth(), BIRTH.getDate());
        }
        const ms = now.getTime() - anniv.getTime();
        const days = Math.floor(ms / 86_400_000);
        const rem = ms % 86_400_000;
        const hh = Math.floor(rem / 3_600_000);
        const mm = Math.floor((rem % 3_600_000) / 60_000);
        return { years, days, hh, mm };
      }

      function colorCmd(p: Proc) {
        const c = esc(p.cmd);
        if (p.kind === 'kernel') return `<span class="c-kernel">${c}</span>`;
        if (p.kind === 'job') return `<span class="c-job">${c}</span>`;
        return `<span class="c-proj">${c}</span>`;
      }

      function colorState(s: string) {
        const cls = s === 'R' ? 'c-run' : s === 'Z' ? 'c-zombie' : 'c-sleep';
        return `<span class="${cls}">${s}</span>`;
      }

      function row(p: Proc) {
        return (
          pad(p.pid, 5) + ' ' +
          padE(p.user, 8) + ' ' +
          pad(p.pr, 3) + ' ' +
          pad(p.ni, 3) + ' ' +
          pad(p.virt, 7) + ' ' +
          pad(p.res, 6) + ' ' +
          pad(p.shr, 6) + ' ' +
          colorState(p.s) + ' ' +
          pad(p.cpu.toFixed(1), 5) + ' ' +
          pad(p.mem.toFixed(1), 5) + ' ' +
          pad(p.time, 10) + ' ' +
          colorCmd(p)
        );
      }

      const HEADER =
        '  PID USER      PR  NI    VIRT    RES    SHR S  %CPU  %MEM      TIME+ COMMAND';

      function render() {
        const now = new Date();
        const clock = `${two(now.getHours())}:${two(now.getMinutes())}:${two(now.getSeconds())}`;
        const u = uptime(now);

        // jitter cpu + re-sort, like top's default refresh.
        for (const p of base) {
          if (p.kind === 'project') {
            p.cpu = Math.max(0, +(p.baseCpu * (1 + rand(-0.18, 0.18))).toFixed(1));
          } else {
            p.cpu = Math.max(0, +(p.baseCpu + rand(-1.5, 1.5)).toFixed(1));
          }
        }
        const sorted = [...base].sort((a, b) => b.cpu - a.cpu);

        const running = sorted.filter((p) => p.s === 'R').length;
        const sleeping = sorted.filter((p) => p.s === 'S').length;
        const zombie = sorted.filter((p) => p.s === 'Z').length;
        const total = sorted.length;

        load = load.map((v, i) =>
          +(Math.max(0.05, v + rand(-0.04, 0.04) - i * 0.0005)).toFixed(2)
        );

        const totalCpu = sorted.reduce((s, p) => s + p.cpu, 0);
        const us = Math.min(96, totalCpu / 8);
        const sy = rand(2, 6);
        const id = Math.max(0, 100 - us - sy);

        const l1 =
          `<span class="hi">top - ${clock} up ` +
          `<span class="c-up">${u.years} years, ${u.days} days, ${two(u.hh)}:${two(u.mm)}</span>` +
          `,  1 user,  load average: ${load[0].toFixed(2)}, ${load[1].toFixed(2)}, ${load[2].toFixed(2)}</span>`;

        const l2 =
          `Tasks: <b>${total}</b> total, ` +
          ` <span class="c-run">${running} running</span>, ` +
          `<span class="c-sleep">${sleeping} sleeping</span>, ` +
          `  0 stopped, ` +
          ` <span class="c-zombie">${zombie} zombie</span>`;

        const l3 =
          `%Cpu(s): <b>${us.toFixed(1)}</b> us, <b>${sy.toFixed(1)}</b> sy,  0.0 ni, ` +
          `<b>${id.toFixed(1)}</b> id,  0.0 wa,  0.0 hi,  0.0 si,  0.0 st`;

        const l4 = 'MiB Mem :  <b>64000.0</b> total, <b>11240.6</b> free, <b>40118.2</b> used, <b>12641.2</b> buff/cache';
        const l5 = 'MiB Swap:   8192.0 total,  8000.4 free,   191.6 used. <b>20402.7</b> avail Mem';

        const lines = [
          l1, l2, l3, l4, l5, '',
          `<span class="colhdr">${esc(HEADER)}</span>`,
          ...sorted.map(row),
          '',
          `<span class="prompt">ben@benwyrosdick</span>:<span class="path">~</span>$ ` +
            `<span class="hint">press <b>q</b> to quit → benwyrosdick.com</span><span class="cursor">▋</span>`,
        ];

        document.getElementById('screen')!.innerHTML = lines.join('\n');
      }

      render();
      setInterval(render, 1000);

      // Client-side refresh: re-fetch GitHub on load so the last-push (and
      // everything derived from it) is always current, no rebuild needed.
      // The build-time data above is the instant paint + offline fallback.
      type Repo = { name: string; lang: string | null; size: number; created: string; pushed: string };

      function mapRepo(r: Repo, i: number, now: number): Proc & { baseCpu: number } {
        const DAY = 86_400_000;
        const between = (a: number, b: number) => Math.max(0, Math.floor((b - a) / DAY));
        const created = new Date(r.created + 'T00:00:00').getTime();
        const pushed = new Date(r.pushed + 'T00:00:00').getTime();
        const daysActive = Math.max(1, between(created, pushed));
        const daysIdle = between(pushed, now);

        const cpu = Math.max(0.1, +(62 * Math.exp(-daysIdle / 45)).toFixed(1));
        const s = daysIdle < 21 ? 'R' : daysIdle > 300 ? 'Z' : 'S';

        const resMiB = Math.max(2, Math.round(r.size / 8));
        const virt = resMiB * 5 + 142;
        const shr = Math.round(resMiB / 4) + 8;
        const mem = +Math.min(48, (resMiB / 64000) * 100).toFixed(1);

        const totalSecs = daysActive * 60;
        const time = `${Math.floor(totalSecs / 60)}:${two(totalSecs % 60)}.${String((r.name.length * 7) % 100).padStart(2, '0')}`;
        const cmd = r.lang ? `${r.name} --lang=${r.lang.toLowerCase()}` : r.name;

        return {
          pid: 1024 + i * 173 + (r.size % 97),
          user: 'ben', pr: '20', ni: 5, virt, res: resMiB, shr, s, cpu, mem, time, cmd,
          kind: 'project', baseCpu: cpu,
        };
      }

      async function refreshFromGitHub() {
        try {
          const res = await fetch(
            'https://api.github.com/users/benwyrosdick/repos?per_page=100&sort=pushed'
          );
          if (!res.ok) return; // rate-limited or offline: keep baked data
          const json = (await res.json()) as any[];
          const repos: Repo[] = json
            .filter((r) => !r.fork && !r.archived)
            .slice(0, 12)
            .map((r) => ({
              name: r.name,
              lang: r.language,
              size: r.size,
              created: r.created_at.slice(0, 10),
              pushed: r.pushed_at.slice(0, 10),
            }));
          if (!repos.length) return;

          const now = Date.now();
          const specials = base.filter((p) => p.kind !== 'project');
          const projects = repos.map((r, i) => mapRepo(r, i, now));
          base = [...specials, ...projects];
          render();
        } catch {
          /* keep baked data */
        }
      }

      refreshFromGitHub();

      document.addEventListener('keydown', (e) => {
        if (e.key === 'q' || e.key === 'Q') window.location.href = '/';
      });
    </script>

    <style>
      :root {
        --bg: #0b0e14;
        --fg: #c8d0dc;
        --frame: #11151f;
      }
      html, body {
        margin: 0;
        background: #05070b;
        min-height: 100%;
      }
      body {
        display: flex;
        justify-content: center;
        padding: clamp(8px, 4vw, 48px);
        box-sizing: border-box;
        font-family: "SF Mono", "JetBrains Mono", "Fira Code", Menlo, Consolas, monospace;
      }
      .term {
        width: 100%;
        max-width: 980px;
        background: var(--bg);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255, 255, 255, 0.04);
      }
      .titlebar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        background: var(--frame);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }
      .dots { display: inline-flex; gap: 8px; }
      .dots i {
        width: 12px; height: 12px; border-radius: 50%; display: inline-block;
      }
      .dots .r { background: #ff5f56; }
      .dots .y { background: #ffbd2e; }
      .dots .g { background: #27c93f; }
      .title {
        color: #8b94a3;
        font-size: 13px;
        margin: 0 auto;
        transform: translateX(-24px);
      }
      .screen {
        margin: 0;
        padding: 16px 18px 20px;
        color: var(--fg);
        font-size: clamp(10px, 2.4vw, 14px);
        line-height: 1.45;
        white-space: pre;
        overflow-x: auto;
        tab-size: 4;
      }
      .hi { background: rgba(255, 255, 255, 0.04); }
      .colhdr {
        background: #1f2633;
        color: #e7ecf3;
        font-weight: 700;
      }
      b { color: #e7ecf3; font-weight: 700; }
      .c-up { color: #7aa2f7; font-weight: 700; }
      .c-run { color: #7ee787; }
      .c-sleep { color: #6e7681; }
      .c-zombie { color: #ff7b72; }
      .c-kernel { color: #56d4dd; font-weight: 700; }
      .c-job { color: #e3b341; font-weight: 700; }
      .c-proj { color: #c8d0dc; }
      .prompt { color: #7ee787; font-weight: 700; }
      .path { color: #7aa2f7; }
      .hint { color: #6e7681; }
      .cursor {
        color: #c8d0dc;
        animation: blink 1.1s steps(1) infinite;
      }
      @keyframes blink { 50% { opacity: 0; } }
    </style>
  </body>
</html>
