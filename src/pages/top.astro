---
import TopTerminal from '../components/TopTerminal.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>top - ben@benwyrosdick</title>
    <meta name="description" content="Ben Wyrosdick — about, rendered as the unix top command." />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="top-page">
    <TopTerminal />
    <p class="top-hint">press <b>q</b> to quit → benwyrosdick.com</p>
    <noscript>
      <p class="top-noscript">
        This page renders with JavaScript. Read the plain version on the
        <a href="/about">about page</a>.
      </p>
    </noscript>
  </body>
</html>

<style is:global>
  html, body { margin: 0; background: #05070b; min-height: 100%; }
  body.top-page {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: clamp(8px, 4vw, 48px);
    box-sizing: border-box;
  }
  .top-noscript {
    font-family: monospace;
    color: #c0c0c0;
    padding: 1rem;
  }
  .top-noscript a { color: #7aa2f7; }
  .top-hint {
    font-family: "SF Mono", "JetBrains Mono", "Fira Code", Menlo, Consolas, monospace;
    color: #99a3b3;
    font-size: 13px;
    margin: 14px 0 0;
  }
  .top-hint b { color: #d7dde7; }
</style>
